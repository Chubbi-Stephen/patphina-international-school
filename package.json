{
  "name": "patphina-school-system",
  "version": "1.0.0",
  "description": "Patphina International School Management System",
  "private": true,
  "scripts": {
    "setup": "node server/db/seed.js",
    "dev": "concurrently \"nodemon server/index.js\" \"npm run dev --prefix client\"",
    "start": "node server/index.js",
    "build": "npm run build --prefix client",
    "install:all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
